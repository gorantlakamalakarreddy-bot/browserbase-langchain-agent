# ============================================================
# Browserbase + LangChain Web Browsing Agent — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# --- Browserbase (Required) ---
BROWSERBASE_API_KEY=bb_live_...
BROWSERBASE_PROJECT_ID=prj_...

# --- Main Planner LLM (Required — choose one) ---
OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# --- Stagehand model overrides (Optional) ---
# STAGEHAND_MODEL=google/gemini-3-flash-preview
# STAGEHAND_AGENT_MODEL=anthropic/claude-sonnet-4-6
